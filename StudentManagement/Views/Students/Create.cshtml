@model StudentManagement.Models.StudentViewModel
@{
    ViewData["Title"] = "Add Student";
}

<div style="max-width:800px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:28px">
        <a asp-action="Index" class="btn btn-ghost btn-sm">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
            <h2 style="font-size:1.05rem;font-weight:700">Add New Student</h2>
            <p style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Fill in all required fields to register a student</p>
        </div>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" id="studentForm">
        @Html.AntiForgeryToken()

        <div class="form-card">

            <!-- Profile Photo -->
            <div style="margin-bottom:28px">
                <div class="form-label" style="margin-bottom:10px">Profile Photo</div>
                <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap">
                    <div id="imagePreviewWrap" style="display:none" class="image-preview-wrap">
                        <img id="imagePreview" src="" alt="Preview" class="image-preview" />
                        <button type="button" class="image-preview-remove" onclick="clearImage()">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                    <div class="image-upload-area" id="uploadPlaceholder" style="flex:1;min-width:200px">
                        <input type="file" name="ProfileImage" id="profileImageInput"
                               accept=".jpg,.jpeg,.png" />
                        <div class="upload-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                        <div class="upload-text">Click or drag to upload</div>
                        <div class="upload-hint">JPG, PNG · max 5MB</div>
                    </div>
                </div>
                <span asp-validation-for="ProfileImage" class="field-error"></span>
            </div>

            <div style="height:1px;background:var(--border);margin-bottom:24px"></div>

            <!-- Personal Details -->
            <div style="margin-bottom:8px;font-size:0.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;font-weight:700">
                Personal Details
            </div>

            <div class="form-grid" style="margin-bottom:20px">
                <div class="form-group">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-input" placeholder="e.g. Sipho" />
                    <span asp-validation-for="FirstName" class="field-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span></span>
                    </span>
                </div>

                <div class="form-group">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-input" placeholder="e.g. Dlamini" />
                    <span asp-validation-for="LastName" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" type="email" class="form-input" placeholder="student@example.com" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MobileNumber" class="form-label"></label>
                    <input asp-for="MobileNumber" class="form-input" placeholder="e.g. 0821234567" />
                    <span asp-validation-for="MobileNumber" class="field-error"></span>
                </div>
            </div>

            <div style="height:1px;background:var(--border);margin-bottom:24px"></div>

            <!-- Academic Details -->
            <div style="margin-bottom:8px;font-size:0.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.08em;font-weight:700">
                Academic Details
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Course" class="form-label"></label>
                    <input asp-for="Course" class="form-input" placeholder="e.g. Computer Science" />
                    <span asp-validation-for="Course" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EnrollmentStatus" class="form-label"></label>
                    <select asp-for="EnrollmentStatus" class="form-select"
                            asp-items="Html.GetEnumSelectList<StudentManagement.Models.EnrollmentStatus>()">
                    </select>
                    <span asp-validation-for="EnrollmentStatus" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Year" class="form-label">Year of Study</label>
                    <select asp-for="Year" class="form-select">
                        @for (int y = 1; y <= 7; y++)
                        {
                            <option value="@y">Year @y</option>
                        }
                    </select>
                    <span asp-validation-for="Year" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="GPA" class="form-label">GPA (0.0 – 4.0)</label>
                    <input asp-for="GPA" type="number" step="0.01" min="0" max="4"
                           class="form-input" placeholder="e.g. 3.50" />
                    <span asp-validation-for="GPA" class="field-error"></span>
                </div>
            </div>

            <!-- Actions -->
            <div style="display:flex;gap:12px;margin-top:28px;padding-top:24px;border-top:1px solid var(--border)">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fa-solid fa-floppy-disk"></i> Save Student
                </button>
                <a asp-action="Index" class="btn btn-ghost btn-lg">Cancel</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function clearImage() {
            document.getElementById('imagePreview').src = '';
            document.getElementById('imagePreviewWrap').style.display = 'none';
            document.getElementById('uploadPlaceholder').style.display = '';
            document.getElementById('profileImageInput').value = '';
        }
    </script>
}
