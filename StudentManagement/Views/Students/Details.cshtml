@model StudentManagement.Models.Student
@{
    ViewData["Title"] = Model.FullName;
}

<div style="max-width:720px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:28px">
        <a asp-action="Index" class="btn btn-ghost btn-sm">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
            <h2 style="font-size:1.05rem;font-weight:700">Student Profile</h2>
            <p style="font-size:0.8rem;color:var(--text-muted);margin-top:2px">Full student record</p>
        </div>
        <div style="margin-left:auto;display:flex;gap:8px">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-pen"></i> Edit
            </a>
        </div>
    </div>

    <div class="card">
        <!-- Header -->
        <div style="display:flex;align-items:center;gap:20px;margin-bottom:28px;padding-bottom:24px;border-bottom:1px solid var(--border)">
            @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
            {
                <img src="@Model.ProfileImageUrl" alt="@Model.FullName"
                     style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid var(--border)" />
            }
            else
            {
                <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--purple));display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;color:white;flex-shrink:0">
                    @Model.FirstName[0]
                </div>
            }
            <div>
                <h3 style="font-size:1.3rem;font-weight:700">@Model.FullName</h3>
                <p style="color:var(--text-muted);font-family:var(--font-mono);font-size:0.82rem;margin-top:4px">@Model.StudentNumber</p>
                <div style="margin-top:8px">
                    <span class="badge @Model.StatusBadgeClass">
                        <i class="fa-solid fa-circle" style="font-size:6px"></i>
                        @Model.EnrollmentStatus
                    </span>
                </div>
            </div>
        </div>

        <!-- Details Grid -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
            @{
                void Field(string label, string value, string icon = "fa-circle-info") {
                    <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius);padding:16px">
                        <div style="font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px">
                            <i class="fa-solid @icon" style="margin-right:4px"></i>@label
                        </div>
                        <div style="font-weight:500;font-size:0.9rem">@(string.IsNullOrEmpty(value) ? "—" : value)</div>
                    </div>
                }
            }

            @{ Field("Email", Model.Email, "fa-envelope"); }
            @{ Field("Mobile", Model.MobileNumber, "fa-phone"); }
            @{ Field("Course", Model.Course, "fa-book"); }
            @{ Field("Year of Study", $"Year {Model.Year}", "fa-calendar"); }
            @{ Field("GPA", Model.GPA.ToString("F2") + " / 4.00", "fa-chart-line"); }
            @{ Field("Enrolled", Model.CreatedAt.ToString("dd MMMM yyyy"), "fa-clock"); }
            @{ Field("Last Updated", Model.UpdatedAt.ToString("dd MMMM yyyy HH:mm"), "fa-pen"); }
            @{ Field("Record ID", Model.Id, "fa-fingerprint"); }
        </div>

        <!-- Actions -->
        <div style="display:flex;gap:10px;margin-top:24px;padding-top:20px;border-top:1px solid var(--border)">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="fa-solid fa-pen"></i> Edit Student
            </a>

            <form method="post" asp-action="SoftDelete" asp-route-id="@Model.Id" id="softFormDetail">
                @Html.AntiForgeryToken()
                <button type="button" class="btn btn-ghost"
                        data-soft-delete data-student-name="@Model.FullName" data-form-id="softFormDetail">
                    <i class="fa-solid fa-user-slash"></i> Deactivate
                </button>
            </form>

            <form method="post" asp-action="Delete" asp-route-id="@Model.Id" id="delFormDetail">
                @Html.AntiForgeryToken()
                <button type="button" class="btn btn-ghost" style="color:var(--red);border-color:rgba(239,68,68,0.3)"
                        data-hard-delete data-student-name="@Model.FullName" data-form-id="delFormDetail">
                    <i class="fa-solid fa-trash"></i> Delete Permanently
                </button>
            </form>
        </div>
    </div>
</div>
